# Copy this file to .env and fill in your values.
# Never commit .env — it contains secrets.

# Supabase — from your project's Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key-here   # service_role key (not anon)
SUPABASE_JWT_SECRET=your-jwt-secret-here  # Settings > API > JWT Settings

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# Nginx-RTMP LXC (change to your LXC IP in production)
RTMP_STAT_URL=http://localhost:8080/stat
NGINX_CONFIG_PATH=/etc/nginx/nginx.conf

# Frontend origin for CORS (change to your actual frontend URL)
FRONTEND_ORIGIN=http://localhost:3000

# Phase 4: Platform APIs (not required for v1)
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=
FACEBOOK_ACCESS_TOKEN=
FACEBOOK_PAGE_ID=

